<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle Information -->
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    
    <!-- URL Scheme for deep linking -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.fluxer.mobile</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>fluxer</string>
            </array>
        </dict>
    </array>
    
    <!-- Required Device Capabilities -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>armv7</string>
    </array>
    
    <!-- Supported Interface Orientations -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Privacy Descriptions -->
    <!-- Microphone - Required for voice messages and calls -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Fluxer needs microphone access to record and send voice messages, and for voice calls.</string>
    
    <!-- Camera - Required for video calls and taking photos -->
    <key>NSCameraUsageDescription</key>
    <string>Fluxer needs camera access for video calls and to take photos for sharing.</string>
    
    <!-- Photo Library - Required for sharing images/videos -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Fluxer needs photo library access to share images and videos in messages.</string>
    
    <!-- Local Network - Required for WebRTC voice/video calls -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Fluxer uses local network discovery to find the best connection for voice and video calls.</string>
    
    <!-- Siri - Required for voice commands -->
    <key>NSSiriUsageDescription</key>
    <string>Fluxer uses Siri to let you send messages, start calls, and control the app hands-free.</string>
    
    <!-- User Notifications - Required for push notifications -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
        <string>voip</string>
        <string>audio</string>
    </array>
    
    <!-- NSUserActivity Types for Siri/Handoff -->
    <key>NSUserActivityTypes</key>
    <array>
        <string>INSendMessageIntent</string>
        <string>INStartCallIntent</string>
        <string>INSearchForMessagesIntent</string>
        <string>INSetMessageAttributeIntent</string>
        <string>com.fluxer.startCall</string>
        <string>com.fluxer.viewMessage</string>
        <string>com.fluxer.siri.openApp</string>
    </array>
    
    <!-- App Groups for sharing data with extensions -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.fluxer.mobile</string>
    </array>
    
    <!-- Keychain Sharing -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.fluxer.mobile</string>
    </array>
    
    <!-- Launch Screen (required for full-screen on all devices) -->
    <key>UILaunchScreen</key>
    <dict/>
    
    <!-- Scene Configuration -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>
</dict>
</plist>
